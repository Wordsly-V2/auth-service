# ── auth-service ──────────────────────────────────────────────────────────
# Copy to `.env` and fill in. Vars marked (required) are validated at boot
# (src/config/validate-env.ts) — the service will refuse to start without them.

# HTTP port (defaults to 3001).
PORT=3001

# Comma-separated list of allowed CORS origins.
CORS_ENABLED_ORIGINS=http://localhost:4000

# (required) PostgreSQL connection string.
DATABASE_URL=postgresql://wordsly:wordsly@localhost:5432/auth?schema=public

# (required) Redis connection string.
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# (required) Signing key (RSA private key or shared secret).
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# (required) Shared secret for gateway → auth-service internal calls.
INTERNAL_SERVICE_TO_SERVICE_TOKEN=
